<Window x:Class="SkyAlpsACARS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SkyAlps Virtual ACARS" Height="600" Width="900"
        Background="{StaticResource BackgroundDark}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SkyAlpsBlue}" Padding="20">
            <StackPanel>
                <TextBlock Text="SKYALPS VIRTUAL ACARS" 
                          FontSize="28" FontWeight="Bold" 
                          Foreground="{StaticResource SkyAlpsGold}"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Flight Data Tracking System" 
                          FontSize="14" 
                          Foreground="{StaticResource TextLight}"
                          HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - Flight Data -->
            <Border Grid.Column="0" Background="#1A2C42" CornerRadius="10" Margin="0,0,10,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="FLIGHT DATA" FontSize="20" FontWeight="Bold" 
                              Foreground="{StaticResource SkyAlpsGold}" Margin="0,0,0,15"/>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Status -->
                        <TextBlock Text="FLIGHT STATUS:" Foreground="{StaticResource TextLight}" FontWeight="Bold"/>
                        <Border Grid.Column="1" Background="{StaticResource SuccessGreen}" CornerRadius="5" Padding="10,5" Margin="0,0,0,10" HorizontalAlignment="Left">
                            <TextBlock x:Name="txtStatus" Text="ON GROUND" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        
                        <!-- Airspeed -->
                        <TextBlock Grid.Row="1" Text="AIRSPEED:" Foreground="{StaticResource TextLight}" FontWeight="Bold"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock x:Name="txtAirspeed" Text="0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SkyAlpsLight}"/>
                            <TextBlock Text=" kts" FontSize="14" Foreground="{StaticResource TextLight}" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        
                        <!-- Altitude -->
                        <TextBlock Grid.Row="2" Text="ALTITUDE:" Foreground="{StaticResource TextLight}" FontWeight="Bold"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock x:Name="txtAltitude" Text="0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SkyAlpsLight}"/>
                            <TextBlock Text=" ft" FontSize="14" Foreground="{StaticResource TextLight}" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        
                        <!-- Vertical Speed -->
                        <TextBlock Grid.Row="3" Text="VERTICAL SPEED:" Foreground="{StaticResource TextLight}" FontWeight="Bold"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock x:Name="txtVS" Text="0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SkyAlpsLight}"/>
                            <TextBlock Text=" fpm" FontSize="14" Foreground="{StaticResource TextLight}" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        
                        <!-- Latitude -->
                        <TextBlock Grid.Row="4" Text="LATITUDE:" Foreground="{StaticResource TextLight}" FontWeight="Bold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtLatitude" Text="0.000000" Foreground="{StaticResource TextLight}" FontSize="16" Margin="0,0,0,10"/>
                        
                        <!-- Longitude -->
                        <TextBlock Grid.Row="5" Text="LONGITUDE:" Foreground="{StaticResource TextLight}" FontWeight="Bold"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtLongitude" Text="0.000000" Foreground="{StaticResource TextLight}" FontSize="16" Margin="0,0,0,10"/>
                        
                        <!-- Timestamp -->
                        <TextBlock Grid.Row="6" Text="LAST UPDATE:" Foreground="{StaticResource TextLight}" FontWeight="Bold"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="txtTimestamp" Text="--" Foreground="{StaticResource TextLight}" FontSize="14" Margin="0,0,0,10"/>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Right Panel - Controls -->
            <Border Grid.Column="1" Background="#1A2C42" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="CONNECTION" FontSize="20" FontWeight="Bold" 
                              Foreground="{StaticResource SkyAlpsGold}" Margin="0,0,0,15"/>
                    
                    <!-- Simulator Connection -->
                    <TextBlock Text="SIMULATOR" Foreground="{StaticResource TextLight}" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Button x:Name="btnConnect" Content="Connect to MSFS" 
                           Click="BtnConnect_Click"
                           Background="{StaticResource SkyAlpsBlue}" 
                           Foreground="White" FontWeight="Bold"
                           Padding="15,10" Margin="0,0,0,10"
                           BorderThickness="0"/>
                    <TextBlock x:Name="txtConnectionStatus" Text="Not connected" 
                              Foreground="{StaticResource DangerRed}" Margin="0,0,0,20"/>
                    
                    <Separator Background="#2C3E50" Margin="0,0,0,20"/>
                    
                    <!-- Supabase Login -->
                    <TextBlock Text="SKYALPS PORTAL" Foreground="{StaticResource TextLight}" FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <TextBlock Text="Email:" Foreground="{StaticResource TextLight}" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtEmail" Padding="8" Background="#0D1B2A" 
                            Foreground="White" BorderBrush="{StaticResource SkyAlpsBlue}" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Password:" Foreground="{StaticResource TextLight}" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassword" Padding="8" Background="#0D1B2A" 
                                Foreground="White" BorderBrush="{StaticResource SkyAlpsBlue}" Margin="0,0,0,15"/>
                    
                    <Button x:Name="btnLogin" Content="Login to SkyAlps" 
                           Click="BtnLogin_Click"
                           Background="{StaticResource SuccessGreen}" 
                           Foreground="White" FontWeight="Bold"
                           Padding="15,10" Margin="0,0,0,10"
                           BorderThickness="0"/>
                    
                    <Button x:Name="btnLogout" Content="Logout" 
                           Click="BtnLogout_Click"
                           Background="{StaticResource WarningOrange}" 
                           Foreground="White" FontWeight="Bold"
                           Padding="15,10" IsEnabled="False"
                           BorderThickness="0"/>
                    
                    <TextBlock x:Name="txtLoginStatus" Text="" 
                              Foreground="{StaticResource TextLight}" Margin="0,10,0,0"
                              TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource SkyAlpsBlue}" Padding="15">
            <Grid>
                <TextBlock Text="SkyAlps Virtual ACARS v1.0.0" Foreground="{StaticResource TextLight}" HorizontalAlignment="Left"/>
                <TextBlock x:Name="txtFooter" Text="Ready" Foreground="{StaticResource TextLight}" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>